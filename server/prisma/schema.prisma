generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Event ────────────────────────────────────────────────────────────────────
model Event {
  id              Int           @id @default(autoincrement())
  title           String
  sport           String
  city            String
  date            String
  startTime       String
  duration        String
  location        String
  maxParticipants Int
  description     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  participants    Participant[]
  comments        Comment[]
}

// ─── Participant ──────────────────────────────────────────────────────────────
model Participant {
  id        Int    @id @default(autoincrement())
  eventId   Int
  userName  String

  event     Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userName])
  @@index([userName])
}

// ─── Comment ─────────────────────────────────────────────────────────────────
model Comment {
  id        Int      @id @default(autoincrement())
  eventId   Int
  author    String
  content   String
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

// ─── Role ─────────────────────────────────────────────────────────────────────
// 3NF: name is the only non-key attribute, depends only on id.
// Two roles: ADMIN and USER.
model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique  // 'ADMIN' | 'USER'
  description String

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

// ─── Permission ───────────────────────────────────────────────────────────────
// 3NF: action depends only on id. No transitive deps.
// Examples: 'event:create', 'event:delete', 'generator:start', 'user:manage'
model Permission {
  id     Int    @id @default(autoincrement())
  action String @unique  // e.g. 'event:create'

  rolePermissions RolePermission[]
}

// ─── RolePermission (junction: Role ↔ Permission) ────────────────────────────
// Many-to-many resolved as an explicit junction table.
// In 3NF: the only fact is "this role has this permission".
model RolePermission {
  roleId       Int
  permissionId Int

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─── User ─────────────────────────────────────────────────────────────────────
// 3NF: username, passwordHash, displayName all depend only on id.
// No derived or transitive attributes.
model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  passwordHash String
  displayName  String
  createdAt    DateTime   @default(now())

  userRoles    UserRole[]
}

// ─── UserRole (junction: User ↔ Role) ────────────────────────────────────────
// Many-to-many, but in practice each user has exactly one role (ADMIN or USER).
// Using a junction table keeps the schema extensible for multi-role users later.
model UserRole {
  userId Int
  roleId Int

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}
