# Copy to .env and fill in your values. Never commit .env.

# PostgreSQL
DATABASE_URL="postgresql://sportlink:sportlink@localhost:5432/sportlink"

# MongoDB (for chat)
MONGO_URL="mongodb://localhost:27017"
MONGO_DB="sportlink_chat"

# Session and auth token secrets - change these before presenting/deploying.
SESSION_SECRET="sportlink-dev-secret-change-in-prod"
AUTH_TOKEN_SECRET="sportlink-token-secret-change-in-prod"
SESSION_IDLE_TIMEOUT_MS=900000
AUTH_TOKEN_TTL_MS=900000

# HTTPS certificate files, relative to the server folder.
SSL_KEY_PATH="../certs/sportlink-key.pem"
SSL_CERT_PATH="../certs/sportlink-cert.pem"

# Server port
PORT=3001

CLIENT_ORIGINS="https://localhost:5173,https://127.0.0.1:5173,https://10.154.238.55:5173,http://localhost:5173,http://127.0.0.1:5173,http://10.154.238.55:5173"
