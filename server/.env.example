# Copy to .env and fill in your values. Never commit .env.

# PostgreSQL
DATABASE_URL="postgresql://sportlink:sportlink@localhost:5432/sportlink"

# MongoDB (for chat)
MONGO_URL="mongodb://localhost:27017"
MONGO_DB="sportlink_chat"

# Session secret — change this in production!
SESSION_SECRET="sportlink-dev-secret-change-in-prod"

# Server port
PORT=3001
