# Copy to .env and fill in your values. Never commit .env.

# PostgreSQL
DATABASE_URL="postgresql://sportlink:sportlink@localhost:5432/sportlink"

# MongoDB (for chat)
MONGO_URL="mongodb://localhost:27017"
MONGO_DB="sportlink_chat"

# Session secret — change this in production!
SESSION_SECRET="sportlink-dev-secret-change-in-prod"

# Server port
PORT=3001

# Comma-separated frontend URLs allowed to call this API.
# Add your VM URL here if you serve dist from the VM, e.g. http://localhost:3000
CLIENT_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.134:5173"
